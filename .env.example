# Database config
DATABASE_URL=postgresql://nine9jiu@localhost:5432/jiuzhang
REDIS_URL=redis://localhost:6379
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000
REDIS_MAX_RETRIES_PER_REQUEST=3
REDIS_RETRY_DELAY_MAX_MS=2000
# Keep false for most cloud databases where the database is created by the cloud console.
DB_INIT_CREATE_DATABASE=false

# Frontend build-time config
# If empty, forms run in static demo mode and redirect to success pages without network submission.
NEXT_PUBLIC_LEAD_RELAY_URL=http://127.0.0.1:8787/api/leads

# Public site URL for metadata, sitemap, robots.txt, OG images.
# Change this to your production domain before launch.
NEXT_PUBLIC_SITE_URL=https://jiuzhang-zhenxuan.com

# Relay shared secret must NEVER be set as NEXT_PUBLIC_*.
# It is configured server-side only via LEAD_RELAY_SECRET.

# Relay runtime config
LEAD_RELAY_PORT=8787
LEAD_RELAY_SECRET=replace-with-at-least-32-random-characters
LEAD_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
LEAD_CHANNELS=feishu,wecom,dingtalk
LEAD_REQUEST_TIMEOUT_MS=8000
LEAD_RATE_LIMIT_WINDOW_MS=60000
LEAD_RATE_LIMIT_MAX=20
LEAD_CHANNEL_RETRY_COUNT=1
LEAD_CHANNEL_RETRY_BASE_MS=250
NEXT_PUBLIC_LEAD_SUBMIT_TIMEOUT_MS=12000
NEXT_PUBLIC_CAPTCHA_PROVIDER=
NEXT_PUBLIC_AUTH_RELAY_URL=http://127.0.0.1:8787/api/auth
NEXT_PUBLIC_ADMIN_RELAY_URL=http://127.0.0.1:8787/api/admin
NEXT_PUBLIC_DIAGNOSIS_AI_URL=
NEXT_PUBLIC_DIAGNOSIS_TIMEOUT_MS=12000
NEXT_PUBLIC_SUPPORT_AI_URL=
NEXT_PUBLIC_SUPPORT_TIMEOUT_MS=10000

# Use true for local integration tests without calling external services.
LEAD_RELAY_DRY_RUN=true
LEAD_CAPTCHA_REQUIRED=false
CAPTCHA_PROVIDER=
CAPTCHA_SECRET_KEY=
AUTH_CODE_TTL_MS=300000
AUTH_CODE_MAX_ATTEMPTS=5
ADMIN_BOOTSTRAP_EMAIL=admin@jiuzhang.local
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-bootstrap-password
ADMIN_BOOTSTRAP_NAME=九章管理员
ADMIN_BOOTSTRAP_ROLE=owner
ADMIN_SESSION_TTL_MS=28800000

# Feishu Bitable
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_DEMAND_TABLE_ID=
FEISHU_APPLICATION_TABLE_ID=

# WeCom group bot
WECOM_BOT_WEBHOOK_URL=
WECOM_MENTIONED_MOBILE_LIST=

# DingTalk group bot
DINGTALK_BOT_WEBHOOK_URL=
DINGTALK_BOT_SECRET=
DINGTALK_AT_MOBILES=

# WeChat Pay reserved server-side config. Do not expose these as NEXT_PUBLIC_*.
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=
