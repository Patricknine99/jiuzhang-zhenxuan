# Frontend build-time config
# If empty, forms run in static demo mode and redirect to success pages without network submission.
NEXT_PUBLIC_LEAD_RELAY_URL=http://127.0.0.1:8787/api/leads

# Public site URL for metadata, sitemap, robots.txt, OG images.
# Change this to your production domain before launch.
NEXT_PUBLIC_SITE_URL=https://jiuzhang-zhenxuan.com

# Relay shared secret must NEVER be set as NEXT_PUBLIC_*.
# It is configured server-side only via LEAD_RELAY_SECRET.

# Relay runtime config
LEAD_RELAY_PORT=8787
LEAD_RELAY_SECRET=change-me
LEAD_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
LEAD_CHANNELS=feishu,wecom,dingtalk
LEAD_REQUEST_TIMEOUT_MS=8000
LEAD_RATE_LIMIT_WINDOW_MS=60000
LEAD_RATE_LIMIT_MAX=20
LEAD_CHANNEL_RETRY_COUNT=1
LEAD_CHANNEL_RETRY_BASE_MS=250
NEXT_PUBLIC_LEAD_SUBMIT_TIMEOUT_MS=12000
NEXT_PUBLIC_DIAGNOSIS_AI_URL=
NEXT_PUBLIC_DIAGNOSIS_TIMEOUT_MS=12000
NEXT_PUBLIC_SUPPORT_AI_URL=
NEXT_PUBLIC_SUPPORT_TIMEOUT_MS=10000

# Use true for local integration tests without calling external services.
LEAD_RELAY_DRY_RUN=true

# Feishu Bitable
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_DEMAND_TABLE_ID=
FEISHU_APPLICATION_TABLE_ID=

# WeCom group bot
WECOM_BOT_WEBHOOK_URL=
WECOM_MENTIONED_MOBILE_LIST=

# DingTalk group bot
DINGTALK_BOT_WEBHOOK_URL=
DINGTALK_BOT_SECRET=
DINGTALK_AT_MOBILES=
